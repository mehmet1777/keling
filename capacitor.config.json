{
  "appId": "com.keling.app",
  "appName": "KeliNG",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "hostname": "keling-baed0.firebaseapp.com"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": false,
