    },
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "914621538684-dke8dmn875d916ekgprhb35jougml3rd.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    },
    "Browser": {
      "androidCustomTabs": true
    }
